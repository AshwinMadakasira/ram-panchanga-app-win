{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RAM Panchanga",
  "version": "1.0.0",
  "identifier": "com.rayaraastottatramandali.rampanchanga.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run desktop:web",
    "beforeBuildCommand": "npm run desktop:bundle"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RAM Panchanga",
        "width": 1200,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
